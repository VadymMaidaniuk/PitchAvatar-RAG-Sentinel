    },
    {
      "query_id": "q_smoke_billing_dispute",
      "query": "invoice dispute adjustment reason",
      "alpha": 1.0,
      "top_k": 3,
      "threshold": 0.0,
      "document_scope": "all",
      "expectations": {
        "expected_top1": "doc_billing",
        "expected_in_topk_chunk_contains": [
          "customer account id",
          "adjustment reason"
        ],
        "forbidden_docs": [
