        "user_id": "qa-smoke",
        "type": "guide",
        "topic": "billing"
      },
      "min_expected_chunks": 1
    }
  ],
  "queries": [
    {
      "query_id": "q_smoke_release_window",
      "query": "Harbor rollback approval code",
      "alpha": 0.5,
      "top_k": 3,
      "threshold": 0.0,
      "document_scope": "all",
      "expectations": {
        "expected_top1": "doc_release",
        "expected_in_topk": [
          "doc_release"
        ],
        "forbidden_docs": [
          "doc_billing"
        ],
        "expected_top1_chunk_contains": [
          "Harbor release window",
          "rollback approval code RSM-17"
