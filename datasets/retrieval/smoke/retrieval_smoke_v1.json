{
  "dataset_id": "retrieval_smoke_v1",
  "description": "Minimal real-environment retrieval sanity check with document-level and chunk-level expectations.",
  "documents": [
    {
      "key": "doc_release",
      "content": "Harbor release window checklist: deploy only during the Tuesday maintenance window. The rollback approval code RSM-17 must be recorded before traffic is shifted back.",
      "metadata": {
        "user_id": "qa-smoke",
        "type": "runbook",
        "topic": "release"
      },
      "min_expected_chunks": 1
    },
    {
      "key": "doc_billing",
      "content": "Billing support checklist: invoice dispute tickets require the customer account id, billing period, and the adjustment reason before escalation.",
