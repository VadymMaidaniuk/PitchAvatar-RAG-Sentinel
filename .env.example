# Framework-specific configuration.
# Copy to .env and adjust values for your environment.

# Recommended QA setup:
# gRPC endpoint: qa-rag-service-dev.pitchavatar.com:443
# write alias:   dev-rag-index-qa
# read alias:    dev-rag-read-qa
# physical:      dev-rag-index-qa-000001

RAG_SENTINEL_GRPC_TARGET=qa-rag-service-dev.pitchavatar.com:443
RAG_SENTINEL_GRPC_SECURE=true
# Optional for TLS endpoints with custom cert/SNI routing.
RAG_SENTINEL_GRPC_SERVER_NAME=qa-rag-service-dev.pitchavatar.com

RAG_SENTINEL_OPENSEARCH_URL=https://opensearch-dev.pitchavatar.com
RAG_SENTINEL_OPENSEARCH_USERNAME=your-username
RAG_SENTINEL_OPENSEARCH_PASSWORD=your-password
RAG_SENTINEL_OPENSEARCH_VERIFY_CERTS=false

# Preferred OpenSearch targets for OpenSearch-side verification/cleanup only.
# These values are server-side QA environment config and must not be sent in gRPC payloads.
# Manual QA verification confirmed these targets can also be queried directly when white-box
# OpenSearch checks are needed.
RAG_SENTINEL_OPENSEARCH_WRITE_ALIAS=dev-rag-index-qa
RAG_SENTINEL_OPENSEARCH_READ_ALIAS=dev-rag-read-qa
RAG_SENTINEL_OPENSEARCH_PHYSICAL_INDEX=dev-rag-index-qa-000001
# Required safety allowlist. Every configured OpenSearch write/read/physical target must be listed.
RAG_SENTINEL_OPENSEARCH_ALLOWED_TARGETS=dev-rag-index-qa,dev-rag-read-qa,dev-rag-index-qa-000001

# Legacy single-target fallback. Prefer WRITE_ALIAS / READ_ALIAS instead.
# RAG_SENTINEL_INDEX_NAME=dev-rag-index-sentinel

RAG_SENTINEL_AUTO_CREATE_INDEX=true
RAG_SENTINEL_ALLOW_PROTECTED_INDEX=false
RAG_SENTINEL_NAMESPACE=qa-sentinel

RAG_SENTINEL_GRPC_TIMEOUT_SECONDS=30
RAG_SENTINEL_UPSERT_TIMEOUT_SECONDS=120
RAG_SENTINEL_DELETE_TIMEOUT_SECONDS=300
RAG_SENTINEL_REFRESH_WAIT_SECONDS=1
RAG_SENTINEL_CLEANUP_WAIT_TIMEOUT_SECONDS=30
RAG_SENTINEL_SEARCH_TOP_K=10
RAG_SENTINEL_SEARCH_THRESHOLD=0.3
RAG_SENTINEL_ARTIFACTS_DIR=artifacts/runs
# Defaults to false. Set to true only if your QA role is allowed to call OpenSearch delete-by-query.
RAG_SENTINEL_DELETE_FALLBACK_TO_OPENSEARCH=false

# Optional. Useful later for cache or lock diagnostics.
# RAG_SENTINEL_REDIS_URL=redis://localhost:6379/0

# Important for small search fixtures:
# QA verification confirmed BM25 search can require a lower floor such as
# RAG_SERVICE_SEARCH_BM25_MIN_SCORE=0.1; otherwise tiny corpora may return no results.
